# @twcardgame/web — environment variables
# Vite inlines VITE_* vars at build time. For local dev copy to .env.local
# (gitignored). In production set these in the Vercel project's
# Environment Variables UI so they are baked into the deployed bundle.

# Colyseus server WebSocket endpoint. Use wss:// in production.
# Defaults to the current browser host on port 2567 when unset
# (for example, http://192.168.1.74:5173 -> ws://192.168.1.74:2567).
VITE_COLYSEUS_URL=

# Supabase production project. Required together to enable account login,
# decks, collection, and match history. The anon key is public by design.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
