# @twcardgame/server — environment variables
# Copy to .env for local dev (.env is gitignored). In production, set these as
# Fly.io secrets (`fly secrets set KEY=value`), not in a committed file.

# Colyseus WebSocket port. Fly.io sets this via fly.toml [env].
PORT=2567

# Supabase production project. Required together to enable authenticated
# matchmaking and match-history persistence. If either is missing the server
# runs in dev mode (display-name / deckIds fallback, no persistence).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Reconnect grace window before a disconnected player forfeits (ms).
RECONNECT_WINDOW_MS=60000

# Delay before an empty/finished room is disposed (ms).
MATCH_CLEANUP_DELAY_MS=10000

# Bot decision latency in PvE rooms (ms).
BOT_THINK_DELAY_MS=600
